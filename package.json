{
  "name": "sintra-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npx tsx scripts/generate-rss.ts && npx tsx scripts/generate-use-cases-count.ts",
    "build": "next build",
    "start": "next start",
    "update-news": "node scripts/update-news.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "validate-data": "node scripts/validate-data.mjs",
    "validate-content": "tsx scripts/validate-content.ts && tsx scripts/validate-latest-news.ts",
    "test": "tsx --test scripts/tests/*.test.ts",
    "audit:static": "npm run validate-data && npm run validate-content && npm test && npm run typecheck",
    "check": "npm run audit:static && npm run build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "fuse.js": "^7.3.0",
    "lucide-react": "^0.400.0",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.1.0",
    "tailwind-merge": "^2.3.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.170.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "zod": "^4.4.3"
  }
}
